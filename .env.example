## Firebase Web App config JSON (stringified)
# Example:
# REACT_APP_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
REACT_APP_FIREBASE_CONFIG=

## Optional Firestore path namespace (defaults below)
REACT_APP_FIREBASE_APP_ID=rainbow-garden-integrated-v3

## UI-only fake data mode (no Firebase). Use "true" / "false"
REACT_APP_DESIGN_MODE=true

